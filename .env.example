# ── Sponsor integrations (drop in real values; app runs on mocks without them) ──

# Claude inference. Leave blank to use the built-in scripted mock (demo still works).
# When set, Mentor streams, Observer/Connector run real Claude calls, and
# Show/Draw camera+whiteboard vision goes live.
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-opus-4-8

# Nebius (OpenAI-compatible). If set, LLM calls route here instead of Anthropic direct.
# Pick a vision-capable model or Show/Draw fall back to mocks.
VITE_NEBIUS_API_KEY=
VITE_NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
VITE_NEBIUS_MODEL=

# EverOS memory. Leave blank to use the localStorage-backed mock adapter.
VITE_EVEROS_API_KEY=
VITE_EVEROS_BASE_URL=

# Butterbase (real auth + transcripts + connector_events). Blank = local mock.
# Simplest: set just the app id — the Data API (/v1/{id}) and Auth API
# (/auth/{id}) URLs are both derived from it.
VITE_BUTTERBASE_APP_ID=
# Optional explicit overrides (self-hosted / proxy):
VITE_BUTTERBASE_URL=
VITE_BUTTERBASE_AUTH_URL=
# Optional bb_sk_ service key — only used as a fallback when no user is
# logged in. Normal writes use the signed-in user's JWT (RLS-scoped).
VITE_BUTTERBASE_KEY=

# Platform-level key for MCP / CLI (app management + hackathon submission).
# Not read by the app itself — export it in your shell for the Butterbase MCP server.
# BUTTERBASE_API_KEY=bb_sk_...
